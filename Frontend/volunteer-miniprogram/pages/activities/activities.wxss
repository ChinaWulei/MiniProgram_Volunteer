.activity-card {
  position: relative;
}
.activity-cover {
  width: 100%;
  height: 240rpx;
  margin-bottom: 18rpx;
  border-radius: 14rpx;
  background: #e6fffb;
}
.activity-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 18rpx;
}
.activity-actions button {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  line-height: 1;
  margin: 0;
  padding: 0 8rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}
.detail-btn {
  color: #0f766e;
  background: #eefaf7;
}
.ai-btn {
  color: #fff;
  background: #0f766e;
}
.ai-btn.active {
  background: #115e59;
}
.activity-actions button::after {
  border: 0;
}
.ai-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f8fbfb;
  border: 1rpx solid #d9f3ee;
}
.ai-loading {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #0f766e;
  font-size: 25rpx;
}
.spinner {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 4rpx solid #b8eee4;
  border-top-color: #0f766e;
  animation: spin 0.8s linear infinite;
}
.ai-content {
  height: 420rpx;
  max-height: 420rpx;
  overflow: hidden;
}
.ai-content.error {
  height: 96rpx;
  max-height: 96rpx;
}
.ai-content-text {
  white-space: pre-wrap;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.65;
  padding-bottom: 8rpx;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
