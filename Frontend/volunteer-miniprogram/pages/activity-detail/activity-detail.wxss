.detail-page {
  padding-bottom: 330rpx;
  background: #f5f7fb;
  min-height: 100vh;
}
.detail-hero {
  padding: 42rpx 30rpx 54rpx;
  color: #fff;
  background: linear-gradient(135deg, #047857, #16a34a);
}
.status-pill {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, .22);
  font-size: 24rpx;
  font-weight: 700;
}
.detail-title {
  margin-top: 22rpx;
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 900;
}
.detail-sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  opacity: .92;
}
.quota-panel {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  margin: -30rpx 24rpx 22rpx;
  padding: 24rpx 10rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 10rpx 28rpx rgba(16, 24, 40, .08);
}
.quota-item {
  text-align: center;
}
.quota-num {
  font-size: 34rpx;
  font-weight: 900;
  color: #0f766e;
}
.quota-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #667085;
}
.detail-section {
  margin: 0 24rpx 20rpx;
  padding: 26rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, .05);
}
.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #172033;
}
.info-line {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2f7;
  font-size: 26rpx;
  color: #172033;
}
.info-line text:first-child {
  flex: 0 0 150rpx;
  color: #667085;
}
.info-line text:last-child {
  text-align: right;
  line-height: 1.45;
}
.paragraph {
  color: #475467;
  font-size: 28rpx;
  line-height: 1.7;
}
.contact-section {
  margin-bottom: 28rpx;
}
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 -8rpx 24rpx rgba(16, 24, 40, .08);
}
.signup-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  line-height: 1;
  border-radius: 14rpx;
  background: #0f766e;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}
.signup-btn.disabled {
  background: #98a2b3;
  color: #fff;
}
.admin-edit {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  line-height: 1;
  border-radius: 14rpx;
  background: #eef6f5;
  color: #0f766e;
  font-size: 28rpx;
}
.detail-cover {
  width: 100%;
  height: 330rpx;
  margin-bottom: 18rpx;
  border-radius: 20rpx;
  background: #e6fffb;
}
.checkin-tag { padding: 6rpx 12rpx; border-radius: 999rpx; background: #f2f4f7; color: #667085; font-size: 23rpx; }
.checkin-tag.CHECKED_IN { background: #dcfce7; color: #15803d; }
.checkin-tag.MANUAL_CHECKED_IN { background: #dbeafe; color: #2563eb; }
.checkin-tag.LATE_CHECKED_IN { background: #ffedd5; color: #c2410c; }
.checkin-tag.ABSENT { background: #fee2e2; color: #dc2626; }
.checkin-btn { display: flex; align-items: center; justify-content: center; height: 72rpx; line-height: 1; margin-top: 18rpx; border-radius: 16rpx; background: #0f766e; color: #fff; font-size: 27rpx; }
.checkin-btn::after { border: 0; }
.reg-card { display: flex; gap: 14rpx; margin-top: 14rpx; padding: 16rpx; border-radius: 14rpx; background: #f8fbfb; }
.reg-avatar { width: 72rpx; height: 72rpx; line-height: 72rpx; border-radius: 50%; color: #fff; background: #0f766e; text-align: center; font-size: 28rpx; font-weight: 800; }
.reg-main { flex: 1; min-width: 0; }
.reg-row { display: flex; justify-content: space-between; gap: 12rpx; align-items: center; }
.reg-name { color: #172033; font-size: 27rpx; font-weight: 800; }
.reg-status { padding: 5rpx 10rpx; border-radius: 999rpx; color: #0f766e; background: #e6fffb; font-size: 21rpx; }
.reg-meta { margin-top: 7rpx; color: #667085; font-size: 22rpx; line-height: 1.35; }
.match-panel, .ai-panel { margin-top: 12rpx; padding: 14rpx; border-radius: 12rpx; background: #fff; }
.ai-panel { background: #fff7ed; }
.match-row { display: flex; justify-content: space-between; gap: 12rpx; color: #172033; font-size: 24rpx; font-weight: 800; }
.reg-actions { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 12rpx; }
.reg-actions button { display: flex; align-items: center; justify-content: center; width: auto; height: 54rpx; line-height: 1; margin: 0; padding: 0 18rpx; border-radius: 14rpx; color: #0f766e; background: #eefaf7; font-size: 22rpx; }
.reg-actions .danger { color: #dc2626; background: #fee2e2; }
.reg-actions button::after { border: 0; }
.reg-audit-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-top: 14rpx; }
.reg-audit-actions button { display: flex; align-items: center; justify-content: center; height: 68rpx; line-height: 1; margin: 0; border-radius: 14rpx; font-size: 26rpx; font-weight: 800; }
.reg-audit-actions button::after { border: 0; }
.reg-audit-actions .approve { color: #fff; background: #0f766e; }
.reg-audit-actions .reject { color: #dc2626; background: #fee2e2; }
.empty-reg { margin-top: 14rpx; color: #667085; font-size: 24rpx; text-align: center; }
.eval-users { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.eval-user { width: auto; height: 58rpx; line-height: 58rpx; margin: 0; padding: 0 18rpx; border-radius: 14rpx; color: #0f766e; background: #eefaf7; font-size: 23rpx; }
.eval-user.active { color: #fff; background: #0f766e; }
.eval-user::after { border: 0; }
.eval-textarea { width: 100%; min-height: 140rpx; padding: 16rpx; box-sizing: border-box; border-radius: 14rpx; background: #f8fbfb; font-size: 26rpx; }
.eval-card { margin-top: 14rpx; padding: 16rpx; border-radius: 14rpx; background: #f8fbfb; }
.checkin-btn.small { height: 62rpx; line-height: 1; font-size: 24rpx; }
.mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 40; background: rgba(0,0,0,.35); }
.cancel-panel { position: fixed; left: 24rpx; right: 24rpx; bottom: 32rpx; z-index: 41; padding: 24rpx; border-radius: 20rpx; background: #fff; }
.panel-title { color: #172033; font-size: 30rpx; font-weight: 800; }
.cancel-panel textarea { margin-top: 16rpx; min-height: 150rpx; background: #f8fbfb; }
.panel-actions { display: flex; gap: 14rpx; margin-top: 16rpx; }
.panel-actions button { flex: 1; display: flex; align-items: center; justify-content: center; height: 68rpx; line-height: 1; margin: 0; border-radius: 16rpx; color: #0f766e; background: #eefaf7; font-size: 25rpx; }
.panel-actions .danger { color: #fff; background: #dc2626; }
.ai-float { position: fixed; z-index: 30; display: flex; align-items: center; justify-content: center; width: 96rpx; height: 96rpx; margin: 0; padding: 0; background: transparent; }
.robot-icon { position: relative; width: 58rpx; height: 56rpx; filter: drop-shadow(0 8rpx 14rpx rgba(15,118,110,.24)); }
.robot-antenna { position: absolute; left: 50%; top: -8rpx; width: 5rpx; height: 14rpx; border-radius: 5rpx; background: #0f766e; transform: translateX(-50%); }
.robot-antenna::before { content: ""; position: absolute; left: 50%; top: -9rpx; width: 12rpx; height: 12rpx; border-radius: 50%; background: #0f766e; transform: translateX(-50%); }
.robot-head { position: absolute; left: 0; right: 0; top: 9rpx; height: 40rpx; border: 5rpx solid #0f766e; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; gap: 14rpx; box-sizing: border-box; background: #ecfdf5; }
.robot-head::before, .robot-head::after { content: ""; position: absolute; top: 14rpx; width: 8rpx; height: 13rpx; border-radius: 8rpx; background: #0f766e; }
.robot-head::before { left: -11rpx; }
.robot-head::after { right: -11rpx; }
.robot-eye { width: 8rpx; height: 8rpx; border-radius: 50%; background: #0f766e; }
.robot-mouth { position: absolute; left: 20rpx; bottom: 0; width: 18rpx; height: 5rpx; border-radius: 5rpx; background: #0f766e; }
.ai-sheet { position: fixed; z-index: 46; max-height: 760rpx; padding: 22rpx; border-radius: 18rpx; background: #fff; box-shadow: 0 16rpx 40rpx rgba(16,24,40,.16); box-sizing: border-box; }
.sheet-arrow { position: absolute; left: 50%; top: -14rpx; width: 28rpx; height: 28rpx; background: #fff; transform: translateX(-50%) rotate(45deg); border-radius: 4rpx; }
.sheet-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.sheet-title { color: #172033; font-size: 32rpx; font-weight: 900; }
.sheet-close { flex: 0 0 52rpx; width: 52rpx; height: 52rpx; line-height: 48rpx; border-radius: 50%; color: #667085; background: #f2f4f7; text-align: center; font-size: 38rpx; }
.sheet-loading { display: flex; align-items: center; gap: 14rpx; min-height: 180rpx; color: #0f766e; font-size: 26rpx; }
.spinner { width: 32rpx; height: 32rpx; border-radius: 50%; border: 4rpx solid #b8eee4; border-top-color: #0f766e; animation: spin 0.8s linear infinite; }
.sheet-content { height: 430rpx; max-height: 430rpx; margin-top: 18rpx; overflow: hidden; }
.sheet-content.error { height: 96rpx; max-height: 96rpx; }
.ai-msg-row { display: flex; gap: 12rpx; align-items: flex-start; margin-bottom: 16rpx; }
.ai-msg-row.right { flex-direction: row-reverse; }
.ai-avatar { flex: 0 0 48rpx; width: 48rpx; height: 48rpx; line-height: 48rpx; border-radius: 50%; text-align: center; color: #fff; background: #0f766e; font-size: 20rpx; font-weight: 800; }
.ai-msg-row.right .ai-avatar { color: #0f766e; background: #dcfce7; }
.ai-bubble { max-width: 520rpx; padding: 16rpx 18rpx; border-radius: 16rpx; font-size: 25rpx; line-height: 1.65; white-space: pre-wrap; word-break: break-word; box-sizing: border-box; }
.ai-bubble.bot { color: #344054; background: #f8fbfb; }
.ai-bubble.mine { color: #fff; background: #0f766e; }
.followup-row { display: flex; gap: 12rpx; margin-top: 18rpx; }
.followup-row input { flex: 1; height: 70rpx; padding: 0 20rpx; border-radius: 35rpx; background: #f2f4f7; font-size: 25rpx; box-sizing: border-box; }
.followup-row button { flex: 0 0 116rpx; display: flex; align-items: center; justify-content: center; height: 70rpx; line-height: 1; margin: 0; padding: 0; border-radius: 35rpx; color: #fff; background: #0f766e; font-size: 25rpx; white-space: nowrap; writing-mode: horizontal-tb; }
.followup-row button::after { border: 0; }
@keyframes spin { to { transform: rotate(360deg); } }
