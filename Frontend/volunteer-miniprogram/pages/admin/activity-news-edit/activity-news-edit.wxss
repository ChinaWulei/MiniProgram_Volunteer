.edit-page { min-height: 100vh; padding: 24rpx 24rpx 130rpx; background: #f5f7fb; box-sizing: border-box; }
.editor-card, .image-section { padding: 22rpx; border-radius: 18rpx; background: #fff; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.title-input { height: 82rpx; font-size: 34rpx; font-weight: 800; background: #f8fbfb; }
.ai-btn { height: 70rpx; line-height: 70rpx; margin: 16rpx 0; border-radius: 16rpx; color: #fff; background: #0f766e; font-size: 26rpx; }
.content-input { min-height: 620rpx; background: #f8fbfb; line-height: 1.7; }
.image-section { margin-top: 18rpx; }
.section-title { color: #172033; font-size: 30rpx; font-weight: 800; margin-bottom: 14rpx; }
.image-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12rpx; }
.image-item { position: relative; height: 160rpx; }
.image-item image, .add-image { width: 100%; height: 160rpx; border-radius: 14rpx; background: #e6fffb; }
.remove { position: absolute; right: 8rpx; top: 8rpx; width: 36rpx; height: 36rpx; line-height: 32rpx; border-radius: 50%; text-align: center; color: #fff; background: rgba(0,0,0,.5); font-size: 30rpx; }
.add-image { display: flex; align-items: center; justify-content: center; color: #0f766e; font-size: 54rpx; }
.bottom-actions { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(24rpx + env(safe-area-inset-bottom)); display: flex; gap: 14rpx; }
.bottom-actions button { flex: 1; height: 78rpx; line-height: 78rpx; margin: 0; border-radius: 18rpx; font-size: 28rpx; }
.bottom-actions .ghost { color: #0f766e; background: #eefaf7; }
.bottom-actions .primary { color: #fff; background: #0f766e; }
button::after { border: 0; }
