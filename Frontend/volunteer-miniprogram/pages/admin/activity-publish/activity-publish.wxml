<view class="publish-page">
  <view class="page-toolbar">
    <view class="page-title">{{id ? '编辑活动' : '发布活动'}}</view>
    <button class="ai-open-btn" bindtap="openAiGenerate">AI生成活动</button>
  </view>

  <view class="cover-box {{generatedFields.coverImageUrl ? 'ai-filled' : ''}}" bindtap="chooseCover">
    <image wx:if="{{form.coverImageUrl}}" class="cover-preview" src="{{form.coverImageUrl}}" mode="aspectFill"></image>
    <view wx:else class="cover-empty">
      <view class="cover-plus">+</view>
      <view>上传活动封面</view>
    </view>
    <view wx:if="{{aiCoverGenerating}}" class="cover-loading">
      <view class="loading-dot"></view>
      <text>封面生成中...</text>
    </view>
  </view>

  <view class="form-card">
    <input class="{{generatedFields.title ? 'ai-filled' : ''}}" placeholder="活动标题" value="{{form.title}}" data-key="title" bindinput="input" />
    <input class="{{generatedFields.category ? 'ai-filled' : ''}}" placeholder="活动类型，如 校园服务" value="{{form.category}}" data-key="category" bindinput="input" />
    <view class="field-title">活动时间</view>
    <view class="picker-row">
      <picker mode="date" value="{{activityDate}}" bindchange="pickActivityDate">
        <view class="picker-field small">{{activityDate || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{activityClock}}" bindchange="pickActivityClock">
        <view class="picker-field small">{{activityClock || '选择时间'}}</view>
      </picker>
    </view>
    <view class="field-title">报名开始时间</view>
    <view class="picker-row">
      <picker mode="date" value="{{signupStartDate}}" bindchange="pickSignupStartDate">
        <view class="picker-field small">{{signupStartDate || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{signupStartClock}}" bindchange="pickSignupStartClock">
        <view class="picker-field small">{{signupStartClock || '选择时间'}}</view>
      </picker>
    </view>
    <view class="field-title">报名截止时间</view>
    <view class="picker-row">
      <picker mode="date" value="{{deadlineDate}}" bindchange="pickDeadlineDate">
        <view class="picker-field small">{{deadlineDate || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{deadlineClock}}" bindchange="pickDeadlineClock">
        <view class="picker-field small">{{deadlineClock || '选择时间'}}</view>
      </picker>
    </view>
    <view class="field-title">签到有效时段</view>
    <view class="picker-row">
      <picker mode="date" value="{{checkinStartDate}}" bindchange="pickCheckinStartDate">
        <view class="picker-field small">{{checkinStartDate || '开始日期'}}</view>
      </picker>
      <picker mode="time" value="{{checkinStartClock}}" bindchange="pickCheckinStartClock">
        <view class="picker-field small">{{checkinStartClock || '开始时间'}}</view>
      </picker>
    </view>
    <view class="picker-row">
      <picker mode="date" value="{{checkinEndDate}}" bindchange="pickCheckinEndDate">
        <view class="picker-field small">{{checkinEndDate || '结束日期'}}</view>
      </picker>
      <picker mode="time" value="{{checkinEndClock}}" bindchange="pickCheckinEndClock">
        <view class="picker-field small">{{checkinEndClock || '结束时间'}}</view>
      </picker>
    </view>
    <view class="field-title">活动地点与签到位置</view>
    <button class="location-btn" bindtap="chooseLocation">{{form.location ? '重新选择签到地点' : '选择签到地点'}}</button>
    <view wx:if="{{form.location}}" class="location-card">
      <view class="location-name">{{form.location}}</view>
      <view class="location-address">{{form.locationAddress || '已选择地图位置'}}</view>
      <view class="location-coord">签到范围：该位置 500 米内</view>
    </view>
    <view class="two-col">
      <view class="field-box">
        <view class="field-title compact">招募人数</view>
        <view class="field-hint">本次活动计划招募的志愿者名额</view>
        <input class="{{generatedFields.recruitCount ? 'ai-filled' : ''}}" placeholder="请输入人数" type="number" value="{{form.recruitCount}}" data-key="recruitCount" bindinput="input" />
      </view>
      <view class="field-box">
        <view class="field-title compact">服务时长</view>
        <view class="field-hint">每名志愿者完成后计入的小时数</view>
        <input class="{{generatedFields.serviceHours ? 'ai-filled' : ''}}" placeholder="请输入小时数" type="digit" value="{{form.serviceHours}}" data-key="serviceHours" bindinput="input" />
      </view>
    </view>

    <view class="field-title">所需技能</view>
    <view class="skill-grid {{generatedFields.requiredSkills ? 'ai-filled-box' : ''}}">
      <view wx:for="{{skillOptions}}" wx:key="name" class="skill {{item.selected ? 'active' : ''}}" data-name="{{item.name}}" bindtap="toggleSkill">{{item.name}}</view>
    </view>

    <textarea class="{{generatedFields.description ? 'ai-filled' : ''}}" placeholder="活动简介" value="{{form.description}}" data-key="description" bindinput="input" maxlength="-1"></textarea>
    <textarea class="{{generatedFields.requirements ? 'ai-filled' : ''}}" placeholder="报名要求" value="{{form.requirements}}" data-key="requirements" bindinput="input" maxlength="-1"></textarea>
    <textarea class="{{generatedFields.tips ? 'ai-filled' : ''}}" placeholder="活动注意事项" value="{{form.tips}}" data-key="tips" bindinput="input" maxlength="-1"></textarea>
    <textarea class="{{generatedFields.promotionText ? 'ai-filled' : ''}}" placeholder="宣传文案" value="{{form.promotionText}}" data-key="promotionText" bindinput="input" maxlength="-1"></textarea>
    <input placeholder="联系人" value="{{form.contactName}}" data-key="contactName" bindinput="input" />
    <input placeholder="联系电话" value="{{form.contactPhone}}" data-key="contactPhone" bindinput="input" />

    <picker mode="selector" range="{{auditModes}}" bindchange="pickAudit">
      <view class="picker-field">审核方式：{{form.auditMode}}</view>
    </picker>
    <picker mode="selector" range="{{statuses}}" bindchange="pickStatus">
      <view class="picker-field">活动状态：{{form.status}}</view>
    </picker>
  </view>

  <button class="submit-btn" bindtap="submit" loading="{{submitting}}">{{id ? '保存活动' : '发布活动'}}</button>

  <view wx:if="{{aiPanelVisible}}" class="ai-mask" bindtap="closeAiGenerate">
    <view class="ai-sheet" catchtap="noop">
      <view class="ai-sheet-header">
        <view class="ai-title">AI一键生成活动</view>
        <view class="ai-close" bindtap="closeAiGenerate">×</view>
      </view>
      <textarea class="ai-prompt" placeholder="例如：帮我生成一个校园环保宣传活动" value="{{aiPrompt}}" bindinput="inputAiPrompt" maxlength="-1"></textarea>
      <view wx:if="{{aiGenerating}}" class="ai-loading">
        <view class="loading-dot"></view>
        <text>{{aiLoadingText}}</text>
      </view>
      <view class="ai-actions">
        <button class="ai-primary" data-mode="FULL" bindtap="aiGenerate" loading="{{aiGenerating}}">AI生成</button>
        <button class="ai-secondary" data-mode="FULL" bindtap="aiGenerate" disabled="{{aiGenerating}}">重新生成全部</button>
      </view>
      <view class="ai-tools">
        <button data-mode="DESCRIPTION" bindtap="aiGenerate" disabled="{{aiGenerating}}">仅优化简介</button>
        <button data-mode="COVER" bindtap="aiGenerate" disabled="{{aiGenerating}}">仅生成封面</button>
        <button data-mode="SKILLS" bindtap="aiGenerate" disabled="{{aiGenerating}}">仅推荐技能</button>
      </view>
    </view>
  </view>
</view>
