.publish-page { min-height: 100vh; padding: 24rpx 24rpx 140rpx; background: #f5f7fb; box-sizing: border-box; }
.page-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.page-title { color: #172033; font-size: 34rpx; font-weight: 800; }
.ai-open-btn { display: flex; align-items: center; justify-content: center; width: 190rpx; height: 64rpx; line-height: 1; margin: 0; border-radius: 14rpx; color: #fff; background: #2563eb; font-size: 25rpx; font-weight: 700; }
.ai-open-btn::after { border: 0; }
.cover-box { position: relative; height: 310rpx; border-radius: 20rpx; overflow: hidden; background: #e6fffb; box-shadow: 0 10rpx 26rpx rgba(16,24,40,.06); }
.cover-preview { width: 100%; height: 100%; }
.cover-empty { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #0f766e; font-size: 26rpx; }
.cover-plus { width: 74rpx; height: 74rpx; line-height: 70rpx; margin-bottom: 12rpx; border-radius: 50%; border: 3rpx solid #0f766e; text-align: center; font-size: 48rpx; box-sizing: border-box; }
.cover-loading { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; gap: 12rpx; color: #fff; background: rgba(15, 23, 42, .45); font-size: 26rpx; }
.form-card { margin-top: 20rpx; padding: 22rpx; border-radius: 18rpx; background: #fff; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.form-card input, .form-card textarea { background: #f8fbfb; box-sizing: border-box; }
.form-card input { min-height: 76rpx; margin-bottom: 16rpx; padding: 0 18rpx; border-radius: 14rpx; color: #172033; font-size: 26rpx; }
.form-card textarea { width: 100%; min-height: 190rpx; margin-bottom: 16rpx; padding: 18rpx; border-radius: 14rpx; color: #172033; font-size: 26rpx; line-height: 1.55; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
.field-box { min-width: 0; }
.picker-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 16rpx; }
.field-title { margin: 6rpx 0 12rpx; color: #172033; font-size: 27rpx; font-weight: 800; }
.field-title.compact { margin-bottom: 6rpx; font-size: 25rpx; }
.field-hint { min-height: 62rpx; color: #667085; font-size: 22rpx; line-height: 1.4; }
.skill-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 18rpx; padding: 8rpx 0; border-radius: 14rpx; }
.skill { padding: 10rpx 16rpx; border-radius: 999rpx; color: #0f766e; background: #eefaf7; font-size: 24rpx; }
.skill.active { color: #fff; background: #0f766e; }
.location-btn { display: flex; align-items: center; justify-content: center; height: 72rpx; line-height: 1; margin: 0 0 14rpx; border-radius: 14rpx; color: #fff; background: #0f766e; font-size: 26rpx; }
.location-btn::after { border: 0; }
.location-card { margin-bottom: 16rpx; padding: 18rpx; border-radius: 14rpx; background: #f0fdfa; border: 1rpx solid #ccfbf1; }
.location-name { color: #172033; font-size: 27rpx; font-weight: 800; }
.location-address, .location-coord { margin-top: 8rpx; color: #667085; font-size: 23rpx; line-height: 1.4; }
.picker-field { height: 72rpx; line-height: 72rpx; margin-bottom: 16rpx; padding: 0 20rpx; border-radius: 14rpx; color: #0f766e; background: #eefaf7; font-size: 25rpx; }
.picker-field.small { margin-bottom: 0; text-align: center; }
.ai-filled { box-shadow: 0 0 0 2rpx rgba(37, 99, 235, .35) inset; background: #eff6ff !important; }
.ai-filled-box { padding: 10rpx; box-shadow: 0 0 0 2rpx rgba(37, 99, 235, .35) inset; background: #eff6ff; }
.submit-btn { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(24rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; justify-content: center; height: 82rpx; line-height: 82rpx; margin: 0; padding: 0; border-radius: 18rpx; background: #0f766e; color: #fff; font-size: 29rpx; font-weight: 800; box-sizing: border-box; }
.submit-btn::after { border: 0; }
.ai-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 50; display: flex; align-items: flex-end; background: rgba(15,23,42,.36); }
.ai-sheet { width: 100%; max-height: 78vh; padding: 28rpx 24rpx calc(30rpx + env(safe-area-inset-bottom)); border-radius: 28rpx 28rpx 0 0; background: #fff; box-sizing: border-box; }
.ai-sheet-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.ai-title { color: #172033; font-size: 31rpx; font-weight: 800; }
.ai-close { width: 58rpx; height: 58rpx; line-height: 54rpx; text-align: center; color: #667085; font-size: 42rpx; }
.ai-prompt { width: 100%; height: 190rpx; padding: 18rpx; border-radius: 16rpx; color: #172033; background: #f8fafc; font-size: 26rpx; line-height: 1.5; box-sizing: border-box; }
.ai-loading { display: flex; align-items: center; gap: 12rpx; margin-top: 18rpx; color: #2563eb; font-size: 25rpx; }
.loading-dot { width: 26rpx; height: 26rpx; border: 4rpx solid rgba(37,99,235,.22); border-top-color: #2563eb; border-radius: 50%; animation: spin .8s linear infinite; }
.ai-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-top: 20rpx; }
.ai-actions button, .ai-tools button { display: flex; align-items: center; justify-content: center; min-height: 70rpx; line-height: 1.2; margin: 0; border-radius: 14rpx; font-size: 25rpx; }
.ai-actions button::after, .ai-tools button::after { border: 0; }
.ai-primary { color: #fff; background: #2563eb; }
.ai-secondary { color: #2563eb; background: #eff6ff; }
.ai-tools { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; margin-top: 14rpx; }
.ai-tools button { color: #0f766e; background: #eefaf7; font-size: 23rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
