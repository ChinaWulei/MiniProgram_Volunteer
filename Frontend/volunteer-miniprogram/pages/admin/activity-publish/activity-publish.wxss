.publish-page { min-height: 100vh; padding: 24rpx 24rpx 140rpx; background: #f5f7fb; box-sizing: border-box; }
.cover-box { height: 310rpx; border-radius: 20rpx; overflow: hidden; background: #e6fffb; box-shadow: 0 10rpx 26rpx rgba(16,24,40,.06); }
.cover-preview { width: 100%; height: 100%; }
.cover-empty { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #0f766e; font-size: 26rpx; }
.cover-plus { width: 74rpx; height: 74rpx; line-height: 70rpx; margin-bottom: 12rpx; border-radius: 50%; border: 3rpx solid #0f766e; text-align: center; font-size: 48rpx; box-sizing: border-box; }
.form-card { margin-top: 20rpx; padding: 22rpx; border-radius: 18rpx; background: #fff; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.form-card input, .form-card textarea { background: #f8fbfb; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
.field-box { min-width: 0; }
.picker-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 16rpx; }
.field-title { margin: 6rpx 0 12rpx; color: #172033; font-size: 27rpx; font-weight: 800; }
.field-title.compact { margin-bottom: 6rpx; font-size: 25rpx; }
.field-hint { min-height: 62rpx; color: #667085; font-size: 22rpx; line-height: 1.4; }
.skill-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 18rpx; }
.skill { padding: 10rpx 16rpx; border-radius: 999rpx; color: #0f766e; background: #eefaf7; font-size: 24rpx; }
.skill.active { color: #fff; background: #0f766e; }
.location-btn { display: flex; align-items: center; justify-content: center; height: 72rpx; line-height: 1; margin: 0 0 14rpx; border-radius: 14rpx; color: #fff; background: #0f766e; font-size: 26rpx; }
.location-btn::after { border: 0; }
.location-card { margin-bottom: 16rpx; padding: 18rpx; border-radius: 14rpx; background: #f0fdfa; border: 1rpx solid #ccfbf1; }
.location-name { color: #172033; font-size: 27rpx; font-weight: 800; }
.location-address, .location-coord { margin-top: 8rpx; color: #667085; font-size: 23rpx; line-height: 1.4; }
.picker-field { height: 72rpx; line-height: 72rpx; margin-bottom: 16rpx; padding: 0 20rpx; border-radius: 14rpx; color: #0f766e; background: #eefaf7; font-size: 25rpx; }
.picker-field.small { margin-bottom: 0; text-align: center; }
.submit-btn { position: fixed; left: 24rpx; right: 24rpx; bottom: calc(24rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; justify-content: center; height: 82rpx; line-height: 1; margin: 0; border-radius: 18rpx; background: #0f766e; color: #fff; font-size: 29rpx; font-weight: 800; }
.submit-btn::after { border: 0; }
