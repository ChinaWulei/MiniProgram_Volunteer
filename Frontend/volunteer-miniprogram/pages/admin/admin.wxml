<view class="admin-page">
  <view class="dash-hero">
    <view>
      <view class="hero-kicker">管理员 Dashboard</view>
      <view class="hero-title">数计志愿服务管理</view>
    </view>
    <button class="hero-btn" bindtap="create">发布活动</button>
  </view>

  <view class="stats-grid">
    <view class="stat-card" bindtap="goStat" data-type="activities"><view class="stat-num">{{stats.activityTotal || 0}}</view><view class="stat-label">活动总数</view></view>
    <view class="stat-card" bindtap="goStat" data-type="volunteers"><view class="stat-num">{{stats.volunteerTotal || 0}}</view><view class="stat-label">志愿者人数</view></view>
    <view class="stat-card" bindtap="goStat" data-type="hours"><view class="stat-num">{{stats.totalHours || 0}}</view><view class="stat-label">总服务时长</view></view>
    <view class="stat-card urgent" bindtap="goStat" data-type="pending"><view class="stat-num">{{stats.pendingRegistrationTotal || 0}}</view><view class="stat-label">待审核报名</view></view>
  </view>

  <view class="action-grid">
    <button class="primary-btn" bindtap="create">发布活动</button>
    <button class="ghost-btn" bindtap="manageActivities">编辑/结束活动</button>
    <button class="ghost-btn" bindtap="reviewList">审核报名</button>
    <button class="ghost-btn" bindtap="volunteers">志愿者库</button>
    <button class="ghost-btn" bindtap="goAnnouncement">发布公告</button>
  </view>

  <view class="chart-panel">
    <view class="panel-title">活动发布趋势</view>
    <view class="trend-chart">
      <view class="trend-bar" wx:for="{{stats.activityTrend}}" wx:key="label">
        <view class="trend-value">{{item.count}}</view>
        <view class="trend-stick" style="height: {{item.height}}rpx;"></view>
        <view class="trend-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="chart-grid">
    <view class="chart-panel">
      <view class="panel-title">各技能志愿者分布</view>
      <view class="bar-row" wx:for="{{stats.skillStats}}" wx:key="skill">
        <view class="bar-name">{{item.skill}}</view>
        <view class="bar-track"><view class="bar-fill skill-fill" style="width: {{item.percent}}%;"></view></view>
        <view class="bar-num">{{item.count}}</view>
      </view>
    </view>
    <view class="chart-panel">
      <view class="panel-title">签到率统计</view>
      <view class="rate-row" wx:for="{{stats.checkinStats}}" wx:key="id">
        <view class="rate-head">
          <view class="rate-name">{{item.name}}</view>
          <view class="rate-num">{{item.rate}}%</view>
        </view>
        <view class="bar-track"><view class="bar-fill rate-fill" style="width: {{item.rate}}%;"></view></view>
      </view>
    </view>
  </view>

  <view class="rank-grid">
    <view class="panel">
      <view class="panel-title">服务时长排行</view>
      <view class="rank-row chart-rank" wx:for="{{stats.hoursRank}}" wx:key="userId" bindtap="goVolunteer" data-id="{{item.userId}}">
        <view class="rank-main">
          <view class="rank-name">{{index + 1}}. {{item.name}}</view>
          <view class="bar-track"><view class="bar-fill hour-fill" style="width: {{item.percent}}%;"></view></view>
        </view>
        <view class="rank-value">{{item.totalHours}}h</view>
      </view>
    </view>
    <view class="panel">
      <view class="panel-title">积分排行</view>
      <view class="rank-row" wx:for="{{stats.pointsRank}}" wx:key="userId" bindtap="goVolunteer" data-id="{{item.userId}}">
        <view class="rank-name">{{index + 1}}. {{item.name}}</view>
        <view class="rank-value">{{item.creditScore}}</view>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">活动类别统计</view>
    <view class="row" wx:for="{{stats.categoryStats}}" wx:key="category">
      <view class="muted">{{item.category}}</view><view class="tag">{{item.count}}</view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">信用分规则配置</view>
    <view class="rule-row" wx:for="{{creditRules}}" wx:key="id">
      <input class="rule-name" value="{{item.name}}" data-index="{{index}}" data-key="name" bindinput="inputRule" />
      <input class="rule-score" type="number" value="{{item.changeValue}}" data-index="{{index}}" data-key="changeValue" bindinput="inputRule" />
      <button class="ghost-btn mini-btn" data-index="{{index}}" bindtap="saveRule">保存</button>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">最近报名</view>
    <view wx:for="{{stats.recentRegistrations}}" wx:key="id" class="review-card">
      <view class="muted">{{item.user_name}} 报名 {{item.activity_name}} · {{item.status}}</view>
      <view class="row">
        <button wx:if="{{item.status === '待审核'}}" size="mini" class="primary-btn" data-id="{{item.id}}" data-status="已通过" bindtap="review">同意</button>
        <button wx:if="{{item.status === '待审核'}}" size="mini" class="ghost-btn reject-btn" data-id="{{item.id}}" data-status="已拒绝" bindtap="review">拒绝</button>
        <view wx:else class="tag">已处理</view>
      </view>
    </view>
  </view>
</view>
