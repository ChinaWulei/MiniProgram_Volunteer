.admin-page { min-height: 100vh; padding: 24rpx; background: #f5f7fb; box-sizing: border-box; }
.dash-hero { display: flex; align-items: center; justify-content: space-between; padding: 30rpx; border-radius: 20rpx; color: #fff; background: linear-gradient(135deg,#0f766e,#14b8a6); box-shadow: 0 14rpx 32rpx rgba(15,118,110,.22); }
.hero-kicker { font-size: 22rpx; opacity: .9; }
.hero-title { margin-top: 8rpx; font-size: 38rpx; font-weight: 800; }
.hero-sub { margin-top: 8rpx; font-size: 22rpx; opacity: .86; }
.hero-btn { display: flex; align-items: center; justify-content: center; width: 150rpx; height: 62rpx; line-height: 1; margin: 0; padding: 0; border-radius: 31rpx; color: #0f766e; background: #fff; font-size: 24rpx; box-sizing: border-box; }
.filter-panel { margin-top: 18rpx; padding: 18rpx; border-radius: 18rpx; background: #fff; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.range-tabs { display: grid; grid-template-columns: repeat(3,1fr); gap: 12rpx; }
.range-tab { display: flex; align-items: center; justify-content: center; height: 62rpx; line-height: 1; margin: 0; padding: 0; border-radius: 14rpx; color: #475467; background: #f2f4f7; font-size: 24rpx; box-sizing: border-box; }
.range-tab.active { color: #fff; background: #0f766e; }
.date-row { display: grid; grid-template-columns: 1fr 46rpx 1fr; gap: 10rpx; align-items: center; margin-top: 14rpx; }
.date-field { display: flex; align-items: center; justify-content: center; height: 62rpx; border-radius: 14rpx; color: #344054; background: #f8fafc; font-size: 24rpx; }
.date-sep { color: #667085; font-size: 24rpx; text-align: center; }
.stats-grid, .action-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 14rpx; margin-top: 18rpx; }
.stat-card, .panel, .chart-panel, .review-card { background: #fff; border-radius: 18rpx; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.stat-card { padding: 22rpx; }
.stat-card { position: relative; }
.stat-card::after { content: ">"; position: absolute; right: 20rpx; top: 18rpx; color: #98a2b3; font-size: 34rpx; }
.stat-card.urgent { border-left: 6rpx solid #ef4444; }
.stat-num { color: #0f766e; font-size: 40rpx; font-weight: 800; }
.stat-label, .muted { margin-top: 8rpx; color: #667085; font-size: 24rpx; line-height: 1.45; }
.primary-btn, .ghost-btn { display: flex; align-items: center; justify-content: center; height: 72rpx; line-height: 1; margin: 0; padding: 0; border-radius: 16rpx; font-size: 26rpx; box-sizing: border-box; }
.primary-btn { background: #0f766e; color: #fff; }
.ghost-btn { background: #eefaf7; color: #0f766e; }
button::after { border: 0; }
.rank-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-top: 18rpx; }
.panel { margin-top: 18rpx; padding: 22rpx; }
.rank-grid .panel { margin-top: 0; }
.chart-panel { margin-top: 18rpx; padding: 22rpx; }
.chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-top: 18rpx; }
.chart-grid .chart-panel { margin-top: 0; }
.panel-title { color: #172033; font-size: 30rpx; font-weight: 800; margin-bottom: 14rpx; }
.trend-chart { height: 210rpx; display: flex; align-items: flex-end; gap: 12rpx; padding-top: 10rpx; }
.trend-bar { flex: 1; min-width: 0; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; }
.trend-value { height: 28rpx; color: #0f766e; font-size: 20rpx; font-weight: 800; }
.trend-stick { width: 22rpx; min-height: 8rpx; border-radius: 12rpx 12rpx 4rpx 4rpx; background: linear-gradient(180deg,#14b8a6,#0f766e); }
.trend-label { margin-top: 8rpx; color: #667085; font-size: 19rpx; transform: scale(.92); }
.bar-row { display: grid; grid-template-columns: 110rpx 1fr 44rpx; gap: 10rpx; align-items: center; padding: 10rpx 0; }
.bar-name { color: #344054; font-size: 22rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.bar-track { height: 16rpx; overflow: hidden; border-radius: 999rpx; background: #eef2f7; }
.bar-fill { height: 100%; border-radius: 999rpx; }
.skill-fill { background: linear-gradient(90deg,#0f766e,#22c55e); }
.rate-fill { background: linear-gradient(90deg,#2563eb,#06b6d4); }
.hour-fill { background: linear-gradient(90deg,#f59e0b,#ef4444); }
.bar-num { color: #0f766e; font-size: 22rpx; font-weight: 800; text-align: right; }
.rate-row { padding: 10rpx 0; }
.rate-head { display: flex; justify-content: space-between; gap: 12rpx; margin-bottom: 8rpx; }
.rate-name { flex: 1; min-width: 0; color: #344054; font-size: 22rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.rate-num { color: #2563eb; font-size: 22rpx; font-weight: 800; }
.rank-row, .row { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; padding: 10rpx 0; }
.chart-rank { align-items: flex-start; }
.rank-main { flex: 1; min-width: 0; }
.rank-main .bar-track { margin-top: 8rpx; }
.rank-name { flex: 1; min-width: 0; color: #172033; font-size: 24rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.rank-value, .tag { flex: 0 0 auto; padding: 6rpx 12rpx; border-radius: 999rpx; color: #0f766e; background: #e6fffb; font-size: 22rpx; }
.pie-section { display: grid; grid-template-columns: 230rpx 1fr; gap: 22rpx; align-items: center; }
.pie-chart { width: 220rpx; height: 220rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: inset 0 0 0 1rpx rgba(15,23,42,.05); }
.pie-hole { width: 118rpx; height: 118rpx; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; box-shadow: 0 4rpx 12rpx rgba(15,23,42,.08); }
.pie-total { color: #172033; font-size: 34rpx; font-weight: 800; line-height: 1; }
.pie-label { margin-top: 6rpx; color: #667085; font-size: 20rpx; }
.pie-legend { min-width: 0; }
.legend-row { display: grid; grid-template-columns: 18rpx 1fr auto; gap: 10rpx; align-items: center; padding: 8rpx 0; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.legend-name { min-width: 0; color: #344054; font-size: 24rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.legend-value { color: #0f766e; font-size: 22rpx; font-weight: 700; }
.empty-mini { color: #98a2b3; font-size: 24rpx; padding: 18rpx 0; }
.review-card { padding: 18rpx; margin-top: 14rpx; }
.rule-row { display: grid; grid-template-columns: 1fr 120rpx 110rpx; gap: 12rpx; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #edf2f7; }
.rule-name, .rule-score { height: 62rpx; padding: 0 14rpx; border-radius: 12rpx; background: #f8fafc; font-size: 24rpx; box-sizing: border-box; }
.mini-btn { height: 62rpx; line-height: 1; font-size: 23rpx; }
.reject-btn { color: #dc2626; background: #fee2e2; }
