<view class="page">
  <view class="form">
    <input class="input" placeholder="公告标题" value="{{title}}" bindinput="inputTitle" />
    <textarea class="textarea" placeholder="公告正文" value="{{content}}" bindinput="inputContent"></textarea>

    <view class="section-head">
      <text>图片</text>
      <button size="mini" class="ghost-btn" bindtap="chooseImages">上传图片</button>
    </view>
    <view class="image-grid" wx:if="{{imageUrls.length}}">
      <image wx:for="{{imageUrls}}" wx:key="*this" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
    </view>

    <view class="section-head">
      <text>附件</text>
      <button size="mini" class="ghost-btn" bindtap="chooseAttachment">上传附件</button>
    </view>
    <view class="file-row" wx:for="{{attachments}}" wx:key="id">
      <view class="file-name">{{item.fileName}}</view>
      <view class="muted">{{item.fileType}} · {{item.status}}</view>
    </view>

    <view class="actions">
      <button class="ghost-btn" bindtap="saveDraft">保存草稿</button>
      <button class="primary-btn" bindtap="publish">发布并通知</button>
    </view>
  </view>
</view>
