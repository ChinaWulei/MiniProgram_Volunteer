.page { min-height: 100vh; background: #f6f8fb; padding: 24rpx; box-sizing: border-box; }
.form { display: flex; flex-direction: column; gap: 22rpx; }
.input, .textarea { background: #fff; border-radius: 8rpx; padding: 24rpx; box-sizing: border-box; font-size: 30rpx; }
.textarea { min-height: 320rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; font-weight: 700; }
.image-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.image-grid image { width: 100%; height: 180rpx; border-radius: 8rpx; }
.file-row { background: #fff; border-radius: 8rpx; padding: 22rpx; }
.file-name { font-size: 28rpx; font-weight: 700; }
.muted { color: #667085; font-size: 24rpx; margin-top: 8rpx; }
.actions { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; margin-top: 12rpx; }
.primary-btn { background: #0f766e; color: #fff; }
.ghost-btn { background: #fff; color: #0f766e; border: 1rpx solid #b7d8d5; }
