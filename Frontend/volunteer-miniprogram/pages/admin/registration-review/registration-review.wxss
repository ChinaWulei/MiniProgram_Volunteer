.review-page { min-height: 100vh; padding: 24rpx; background: #f5f7fb; box-sizing: border-box; }
.filter-card, .review-card, .empty { background: #fff; border-radius: 18rpx; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.filter-card { padding: 20rpx; }
.filter-card input { margin-bottom: 14rpx; background: #f8fbfb; }
.filter-row { display: flex; gap: 12rpx; align-items: center; }
.filter-row picker { flex: 1; }
.filter-chip { height: 62rpx; line-height: 1.2; padding: 0 16rpx; border-radius: 14rpx; color: #0f766e; background: #eefaf7; font-size: 24rpx; display: flex; align-items: center; justify-content: center; box-sizing: border-box; }
.search-btn { width: 112rpx; height: 62rpx; line-height: 62rpx; margin: 0; padding: 0; border-radius: 14rpx; background: #0f766e; color: #fff; font-size: 24rpx; }
.review-card { margin-top: 18rpx; padding: 20rpx; }
.user-row { display: flex; gap: 14rpx; align-items: center; }
.avatar { width: 78rpx; height: 78rpx; line-height: 78rpx; border-radius: 50%; background: #0f766e; color: #fff; text-align: center; font-size: 30rpx; font-weight: 800; }
.user-main { flex: 1; min-width: 0; }
.name { color: #172033; font-size: 29rpx; font-weight: 800; }
.meta { margin-top: 7rpx; color: #667085; font-size: 23rpx; line-height: 1.35; }
.status { padding: 7rpx 13rpx; border-radius: 999rpx; color: #0f766e; background: #e6fffb; font-size: 22rpx; }
.activity-box { margin-top: 16rpx; padding: 16rpx; border-radius: 14rpx; background: #f8fbfb; }
.activity-title { color: #172033; font-size: 28rpx; font-weight: 800; }
.actions { display: flex; justify-content: flex-end; gap: 12rpx; margin-top: 16rpx; }
.actions button { width: 126rpx; height: 58rpx; line-height: 58rpx; margin: 0; padding: 0; border-radius: 14rpx; color: #0f766e; background: #eefaf7; font-size: 23rpx; }
.actions .danger { color: #dc2626; background: #fee2e2; }
button::after { border: 0; }
.empty { margin-top: 18rpx; padding: 34rpx; color: #667085; text-align: center; }
.mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 40; background: rgba(0,0,0,.35); }
.cancel-panel { position: fixed; left: 24rpx; right: 24rpx; bottom: 32rpx; z-index: 41; padding: 24rpx; border-radius: 20rpx; background: #fff; }
.panel-title { color: #172033; font-size: 30rpx; font-weight: 800; }
.cancel-panel textarea { margin-top: 16rpx; min-height: 150rpx; background: #f8fbfb; }
.panel-actions { display: flex; gap: 14rpx; margin-top: 16rpx; }
.panel-actions button { flex: 1; height: 68rpx; line-height: 68rpx; margin: 0; border-radius: 16rpx; color: #0f766e; background: #eefaf7; font-size: 25rpx; }
.panel-actions .danger { color: #fff; background: #dc2626; }
