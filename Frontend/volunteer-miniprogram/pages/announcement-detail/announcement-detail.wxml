<view class="page" wx:if="{{detail}}">
  <view class="title">{{detail.title}}</view>
  <view class="time">{{detail.publishedAt || detail.createdAt}}</view>
  <view class="content">{{detail.content}}</view>
  <image class="pic" wx:for="{{detail.imageUrls}}" wx:key="*this" src="{{item}}" mode="widthFix" bindtap="previewImage" data-url="{{item}}" />
  <view class="files" wx:if="{{detail.attachments.length}}">
    <view class="section-title">附件</view>
    <view class="file-row" wx:for="{{detail.attachments}}" wx:key="ruleFileId" bindtap="openAttachment" data-url="{{item.url}}">
      <view class="file-name">{{item.fileName}}</view>
      <view class="muted">{{item.fileType}} · 点击打开附件</view>
    </view>
  </view>
</view>
