.page { min-height: 100vh; background: #fff; padding: 32rpx; box-sizing: border-box; }
.title { font-size: 40rpx; font-weight: 800; color: #101828; line-height: 1.35; }
.time { margin-top: 12rpx; color: #667085; font-size: 24rpx; }
.content { margin-top: 30rpx; white-space: pre-wrap; color: #344054; font-size: 30rpx; line-height: 1.75; }
.pic { width: 100%; margin-top: 22rpx; border-radius: 8rpx; }
.files { margin-top: 32rpx; }
.section-title { font-weight: 800; margin-bottom: 14rpx; }
.file-row { padding: 22rpx; background: #f6f8fb; border-radius: 8rpx; margin-bottom: 14rpx; }
.file-name { font-weight: 700; color: #101828; }
.muted { margin-top: 6rpx; color: #667085; font-size: 24rpx; }
