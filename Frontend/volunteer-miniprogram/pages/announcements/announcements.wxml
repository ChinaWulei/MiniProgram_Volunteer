<view class="page">
  <view class="hero">
    <view>
      <view class="kicker">{{isAdmin ? '公告管理' : '学院公告'}}</view>
      <view class="title">{{isAdmin ? '公告列表' : '最新公告'}}</view>
      <view class="sub">{{isAdmin ? '查看、发布和删除公告' : '查看管理员发布的文字、图片和附件通知'}}</view>
    </view>
    <button wx:if="{{isAdmin}}" class="hero-btn" bindtap="create">发布</button>
  </view>

  <view class="notice-card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="card-head">
      <view class="notice-title">{{item.title}}</view>
      <view wx:if="{{isAdmin}}" class="status {{item.status}}">{{item.statusText}}</view>
    </view>
    <view class="notice-time">{{item.timeText}}</view>
    <view class="notice-content">{{item.summary}}</view>
    <view class="notice-meta">
      <text wx:if="{{item.imageCount}}">{{item.imageCount}} 张图片</text>
      <text wx:if="{{item.attachmentCount}}">{{item.attachmentCount}} 个附件</text>
    </view>
    <view wx:if="{{isAdmin}}" class="actions">
      <button class="ghost-btn" catchtap="goDetail" data-id="{{item.id}}">查看</button>
      <button class="danger-btn" catchtap="deleteItem" data-id="{{item.id}}" data-title="{{item.title}}">删除</button>
    </view>
  </view>

  <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无公告</view>
  <view wx:if="{{loading}}" class="empty">加载中...</view>
</view>
