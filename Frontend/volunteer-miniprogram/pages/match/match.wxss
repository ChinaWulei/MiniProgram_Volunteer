
.page { min-height: 100vh; padding: 24rpx; background: #f5f7fb; box-sizing: border-box; }
.hero { padding: 28rpx; border-radius: 18rpx; background: #0f766e; color: #fff; }
.hero-title { font-size: 34rpx; font-weight: 800; display: flex; align-items: center; gap: 12rpx; }
.hero-sub { margin-top: 10rpx; font-size: 24rpx; opacity: .86; line-height: 1.5; }
.info-dot { display: inline-flex; align-items: center; justify-content: center; width: 34rpx; height: 34rpx; border-radius: 50%; color: #0f766e; background: #fff; font-size: 22rpx; font-weight: 800; }
.card { margin-top: 18rpx; padding: 22rpx; border-radius: 16rpx; background: #fff; box-shadow: 0 8rpx 22rpx rgba(16,24,40,.06); }
.row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.title { color: #172033; font-size: 30rpx; font-weight: 800; }
.stat-num { color: #0f766e; font-size: 34rpx; font-weight: 900; }
.muted { margin-top: 10rpx; color: #667085; font-size: 24rpx; line-height: 1.5; }
.empty { margin-top: 24rpx; padding: 30rpx; border-radius: 16rpx; color: #667085; background: #fff; text-align: center; font-size: 26rpx; }
.empty-sub { margin-top: 10rpx; font-size: 23rpx; line-height: 1.5; }
