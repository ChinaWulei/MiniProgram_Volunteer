.registration-card {
  position: relative;
  padding-right: 48rpx;
}
.registration-card::after {
  content: '';
  position: absolute;
  right: 24rpx;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid #98a2b3;
  border-right: 3rpx solid #98a2b3;
  transform: translateY(-50%) rotate(45deg);
}
