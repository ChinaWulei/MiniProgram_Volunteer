.profile-page {
  padding: 24rpx;
  padding-bottom: 48rpx;
}
.profile-header {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 32rpx 26rpx;
  border-radius: 18rpx;
  color: #fff;
  background: linear-gradient(135deg, #0f766e, #16a34a);
  box-shadow: 0 12rpx 30rpx rgba(15, 118, 110, .22);
}
.avatar-wrap {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 132rpx;
}
.avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 66rpx;
  border: 4rpx solid rgba(255, 255, 255, .7);
}
.default-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ecfdf5;
  color: #0f766e;
  font-size: 52rpx;
  font-weight: 800;
}
.avatar-tip {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: -8rpx;
  height: 34rpx;
  line-height: 34rpx;
  text-align: center;
  border-radius: 18rpx;
  background: rgba(0, 0, 0, .45);
  color: #fff;
  font-size: 20rpx;
}
.profile-main {
  flex: 1;
  min-width: 0;
}
.nickname {
  font-size: 38rpx;
  font-weight: 800;
}
.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: .9;
  line-height: 1.35;
}
.hours {
  min-width: 118rpx;
  text-align: center;
  padding: 16rpx 12rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, .16);
}
.hours-num {
  font-size: 38rpx;
  font-weight: 800;
}
.hours-label {
  margin-top: 4rpx;
  font-size: 20rpx;
}
.growth-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, .06);
}
.level-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}
.level {
  color: #172033;
  font-size: 34rpx;
  font-weight: 900;
}
.level-sub {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}
.points {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #15803d;
  font-size: 24rpx;
  font-weight: 800;
}
.progress-track {
  height: 18rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eef2f6;
}
.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0f766e, #22c55e);
}
.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}
.stat-item {
  padding: 18rpx 8rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  text-align: center;
}
.stat-num {
  color: #0f766e;
  font-size: 34rpx;
  font-weight: 900;
}
.stat-label {
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
}
.section {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, .06);
}
.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
}
.badge-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.badge {
  min-height: 126rpx;
  padding: 16rpx 8rpx;
  border-radius: 14rpx;
  background: #f0fdf4;
  text-align: center;
}
.badge-icon {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 10rpx;
  line-height: 48rpx;
  border-radius: 50%;
  background: #16a34a;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
}
.badge-name {
  color: #14532d;
  font-size: 22rpx;
  line-height: 1.25;
  font-weight: 700;
}
.empty-badge {
  padding: 22rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #667085;
  font-size: 26rpx;
  text-align: center;
}
.credit-record { display: flex; justify-content: space-between; gap: 18rpx; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid #edf2f7; }
.credit-reason { color: #172033; font-size: 26rpx; font-weight: 700; }
.credit-time { margin-top: 6rpx; color: #98a2b3; font-size: 22rpx; }
.credit-change { flex: 0 0 auto; font-size: 28rpx; font-weight: 900; }
.credit-change.plus { color: #15803d; }
.credit-change.minus { color: #dc2626; }
.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f7;
  color: #172033;
  font-size: 28rpx;
}
.info-row text:first-child {
  color: #667085;
}
.info-row.column {
  display: block;
}
.info-row.column > text:first-child {
  display: block;
  margin-bottom: 12rpx;
}
.skill-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin: 8rpx 0 18rpx;
}
.skill {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 12rpx;
  background: #f2f4f7;
  color: #344054;
  font-size: 24rpx;
}
.skill.active {
  background: #dcfce7;
  color: #15803d;
  font-weight: 700;
}
.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  height: 78rpx;
  line-height: 1;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 14rpx;
  font-size: 27rpx;
}
.actions button::after { border: 0; }
.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 78rpx;
  line-height: 1;
  margin-top: 18rpx;
  padding: 0;
  color: #dc2626;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.logout-btn::after { border: 0; }
