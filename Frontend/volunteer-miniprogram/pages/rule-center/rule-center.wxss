.rule-page { min-height: 100vh; padding: 24rpx; background: #f5f7fb; box-sizing: border-box; }
.top-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; margin-bottom: 18rpx; }
.primary-btn, .ghost-btn, .download-btn { height: 72rpx; line-height: 72rpx; margin: 0; border-radius: 14rpx; font-size: 26rpx; }
.primary-btn { color: #fff; background: #0f766e; }
.ghost-btn, .download-btn { color: #0f766e; background: #eefaf7; }
button::after { border: 0; }
.file-card { display: flex; gap: 16rpx; align-items: center; padding: 22rpx; margin-bottom: 16rpx; border-radius: 16rpx; background: #fff; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.file-main { flex: 1; min-width: 0; }
.file-title { color: #172033; font-size: 29rpx; font-weight: 800; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.file-meta { margin-top: 8rpx; color: #667085; font-size: 23rpx; }
.download-btn { flex: 0 0 120rpx; width: 120rpx; font-size: 24rpx; }
.empty { padding: 40rpx; border-radius: 16rpx; background: #fff; color: #667085; text-align: center; }
