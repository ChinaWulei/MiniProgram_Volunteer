<view class="qa-page">
  <view class="ask-card">
    <textarea placeholder="输入关于志愿服务规则的问题" value="{{question}}" bindinput="input"></textarea>
    <button class="ask-btn" loading="{{loading}}" bindtap="ask">提问</button>
  </view>

  <view wx:if="{{answer}}" class="answer-card">
    <view class="answer-title">回答</view>
    <view class="answer-text">{{answer}}</view>
    <view wx:if="{{sources.length}}" class="source-title">引用来源</view>
    <view class="source" wx:for="{{sources}}" wx:key="*this">{{item}}</view>
  </view>
</view>
