.qa-page { min-height: 100vh; padding: 24rpx; background: #f5f7fb; box-sizing: border-box; }
.ask-card, .answer-card { padding: 22rpx; border-radius: 16rpx; background: #fff; box-shadow: 0 8rpx 24rpx rgba(16,24,40,.06); }
.ask-card textarea { width: 100%; min-height: 180rpx; padding: 18rpx; box-sizing: border-box; border-radius: 14rpx; background: #f8fbfb; font-size: 27rpx; }
.ask-btn { height: 76rpx; line-height: 76rpx; margin: 18rpx 0 0; border-radius: 14rpx; color: #fff; background: #0f766e; font-size: 27rpx; }
button::after { border: 0; }
.answer-card { margin-top: 18rpx; }
.answer-title, .source-title { color: #172033; font-size: 30rpx; font-weight: 800; }
.answer-text { margin-top: 14rpx; color: #344054; font-size: 27rpx; line-height: 1.7; white-space: pre-wrap; }
.source-title { margin-top: 22rpx; font-size: 26rpx; }
.source { margin-top: 10rpx; padding: 12rpx 16rpx; border-radius: 999rpx; color: #0f766e; background: #eefaf7; font-size: 24rpx; }
